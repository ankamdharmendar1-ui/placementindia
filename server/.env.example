MONGODB_URI=mongodb://localhost:27017/quetext-in
PORT=5000
GOOGLE_CX=your-google-custom-search-cx

# Google Gemini API Keys — comma-separated for auto-rotation on rate limits
# Generate free keys at: https://aistudio.google.com/apikey
# Example with 3 keys: GOOGLE_API_KEYS=key1,key2,key3
GOOGLE_API_KEYS=your-google-api-key-1,your-google-api-key-2,your-google-api-key-3

# Single key for Google Custom Search (plagiarism checker)
GOOGLE_API_KEY=your-google-api-key

# Legacy / backup keys
OPENROUTER_API_KEY=your-openrouter-key
DEEPSEEK_API_KEY=your-deepseek-key
