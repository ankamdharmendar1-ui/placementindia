// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  image         String?
  role          String    @default("USER") // USER, ADMIN
  bio           String?
  skills        String?   // Comma separated
  education     String?
  resumeUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  blogs         BlogPost[]
  applications  Application[]
  savedItems    SavedItem[]
}

model Job {
  id            String    @id @default(cuid())
  title         String
  company       String
  location      String
  salary        String?
  description   String
  eligibility   String
  category      String    // Software, Marketing, etc.
  type          String    @default("Full-time")
  logoUrl       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  applications  Application[]
  savedIn       SavedItem[]
}

model Internship {
  id            String    @id @default(cuid())
  title         String
  company       String
  location      String
  stipend       String?
  duration      String
  description   String
  eligibility   String
  isRemote      Boolean   @default(false)
  category      String
  logoUrl       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  applications  Application[]
  savedIn       SavedItem[]
}

model BlogPost {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  content       String
  excerpt       String?
  coverImage    String?
  authorId      String
  author        User      @relation(fields: [authorId], references: [id])
  published     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  likes         Int       @default(0)
}

model Application {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  jobId         String?
  job           Job?        @relation(fields: [jobId], references: [id])
  internshipId  String?
  internship    Internship? @relation(fields: [internshipId], references: [id])
  status        String      @default("PENDING") // PENDING, REVIEWING, ACCEPTED, REJECTED
  appliedAt     DateTime    @default(now())
}

model SavedItem {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  jobId         String?
  job           Job?        @relation(fields: [jobId], references: [id])
  internshipId  String?
  internship    Internship? @relation(fields: [internshipId], references: [id])
  createdAt     DateTime    @default(now())
}
